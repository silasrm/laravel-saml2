{
    "name": "scaler-tech/laravel-saml2",
    "description": "SAML2 Service Provider integration for Laravel applications, based on OneLogin toolkit",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "laravel",
        "saml",
        "saml2",
        "onelogin",
        "sso"
    ],
    "authors": [
        {
            "name": "Scaler Tech",
            "role": "Maintainer"
        },
        {
            "name": "Artem Brezhnev",
            "email": "brezzhnev@gmail.com"
        }
    ],
    "homepage": "https://github.com/scaler-tech/laravel-saml2",
    "support": {
        "issues": "https://github.com/scaler-tech/laravel-saml2/issues",
        "source": "https://github.com/scaler-tech/laravel-saml2"
    },
    "require": {
        "php": ">=7.1",
        "ext-openssl": "*",
        "illuminate/console": "^5.5 || ^6.0 || ^7.0 || ^8.0 || ^9.0 || ^10.0 || ^11.0 || ^12.0",
        "illuminate/database": "^5.5 || ^6.0 || ^7.0 || ^8.0 || ^9.0 || ^10.0 || ^11.0 || ^12.0",
        "illuminate/support": "^5.5 || ^6.0 || ^7.0 || ^8.0 || ^9.0 || ^10.0 || ^11.0 || ^12.0",
        "onelogin/php-saml": "^3.0 || ^4.0",
        "ramsey/uuid": "^3.8 || ^4.0"
    },
    "require-dev": {
        "mockery/mockery": "^0.9.9",
        "phpunit/phpunit": "^7.5 || ^8.5 || ^9.0",
        "squizlabs/php_codesniffer": "^2.3"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Slides\\Saml2\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Slides\\Saml2\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-aliases": {
            "dev-master": "2.4.x-dev"
        },
        "laravel": {
            "aliases": {
                "Saml2": "Slides\\Saml2\\Facades\\Auth"
            },
            "providers": [
                "Slides\\Saml2\\ServiceProvider"
            ]
        }
    }
}
