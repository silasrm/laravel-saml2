{
    "name": "scaler-tech/laravel-saml2",
    "description": "SAML2 Service Provider integration for Laravel applications, based on OneLogin toolkit",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "laravel",
        "saml",
        "saml2",
        "onelogin",
        "sso"
    ],
    "authors": [
        {
            "name": "Scaler Tech",
            "role": "Maintainer"
        },
        {
            "name": "Artem Brezhnev",
            "email": "brezzhnev@gmail.com"
        }
    ],
    "homepage": "https://github.com/scaler-tech/laravel-saml2",
    "support": {
        "issues": "https://github.com/scaler-tech/laravel-saml2/issues",
        "source": "https://github.com/scaler-tech/laravel-saml2"
    },
    "require": {
        "php": ">=8.2",
        "ext-openssl": "*",
        "illuminate/console": "^9.0 || ^10.0 || ^11.0 || ^12.0",
        "illuminate/database": "^9.0 || ^10.0 || ^11.0 || ^12.0",
        "illuminate/support": "^9.0 || ^10.0 || ^11.0 || ^12.0",
        "onelogin/php-saml": "^4.0",
        "ramsey/uuid": "^4.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^10.5 || ^11.5",
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Slides\\Saml2\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Slides\\Saml2\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "aliases": {
                "Saml2": "Slides\\Saml2\\Facades\\Auth"
            },
            "providers": [
                "Slides\\Saml2\\ServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "@php vendor/bin/phpunit"
    }
}
